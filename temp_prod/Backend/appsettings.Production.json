{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "CorsPolicy": "AllowAngular",
        "RateLimiterPolicy": "LoginRateLimit",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPrefix": "/Auth"
          }
        ]
      },
